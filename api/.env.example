# Postgres DSN. Local dev default; prod uses the Neon pooled URL (set in Render).
DATABASE_URL=postgresql+psycopg2://chronicle:chronicle@localhost:5432/chronicle

# Shared secret for the web -> API internal auth token (HMAC-SHA256).
# Must match the web app's INTERNAL_API_SECRET. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=change-me

# Comma-separated CORS allowlist. Prod: https://chronicles-weld.vercel.app
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
