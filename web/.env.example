# FastAPI base URL (local dev default; prod points at the Render service).
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# Google OAuth client (console.cloud.google.com -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID=change-me
AUTH_GOOGLE_SECRET=change-me

# Shared secret for signing internal API tokens (must match the API's value).
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=change-me
